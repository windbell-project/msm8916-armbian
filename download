#!/bin/bash

set -e

REPO="ophub/amlogic-s9xxx-armbian"
API_URL="https://api.github.com/repos/${REPO}/releases"

# 获取所有 release，提取 arm64 的版本代号（xxx）
echo "正在获取可用的 Armbian arm64 版本列表..."
echo ""

# 从 releases API 获取所有 tag_name，筛选出 arm64 的，提取 xxx 部分
versions=$(wget -qO- -t1 -T10 "${API_URL}" | grep '"tag_name"' | sed 's/.*"tag_name": *"//;s/".*//' | grep -i 'arm64' | sed 's/Armbian_\(.*\)_arm64.*/\1/i' | sort -u)

if [ -z "$versions" ]; then
    echo "错误：无法获取版本列表，请检查网络连接"
    exit 1
fi

# 显示版本列表供用户选择
echo "可用的版本（从 tag: Armbian_xxx_arm64... 中提取的 xxx）："
echo "------------------------------------------------"
i=1
declare -A version_map
while IFS= read -r ver; do
    echo "  [$i] $ver"
    version_map[$i]="$ver"
    ((i++))
done <<< "$versions"
echo "------------------------------------------------"
echo ""

# 用户选择
read -p "请输入要下载的版本编号: " choice

if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ -z "${version_map[$choice]}" ]; then
    echo "错误：无效的选择"
    exit 1
fi

selected_ver="${version_map[$choice]}"
echo ""
echo "您选择的版本: $selected_ver"
echo ""

# 构造完整的 tag 名称（假设格式为 Armbian_xxx_arm64_server_YYYY.MM）
# 需要从 releases 中匹配到完整的 tag_name
full_tag=$(wget -qO- -t1 -T10 "${API_URL}" | grep '"tag_name"' | sed 's/.*"tag_name": *"//;s/".*//' | grep -i "arm64" | grep -i "${selected_ver}" | head -n 1)

if [ -z "$full_tag" ]; then
    echo "错误：无法找到对应的完整 tag"
    exit 1
fi

echo "完整 tag: $full_tag"
echo ""

# 获取该 release 的 assets 列表，筛选包含 trunk 的文件
echo "正在获取该版本的文件列表..."
assets_json=$(wget -qO- -t1 -T10 "${API_URL}/tags/${full_tag}")

# 提取包含 trunk 的 asset 文件名
trunk_file=$(echo "$assets_json" | grep -o '"name": "[^"]*trunk[^"]*"' | head -n 1 | awk -F '"' '{print $4}')

if [ -z "$trunk_file" ]; then
    echo "错误：该版本下未找到包含 'trunk' 的文件"
    echo "该版本可用的文件："
    echo "$assets_json" | grep -o '"name": "[^"]*"' | awk -F '"' '{print $4}' | grep -E '\.(img|gz|xz|zip)$' || true
    exit 1
fi

echo "找到文件: $trunk_file"
echo ""

# 下载文件
download_url="https://github.com/${REPO}/releases/download/${full_tag}/${trunk_file}"
echo "开始下载: ${download_url}"
echo ""

wget --show-progress -c "${download_url}" -O "${trunk_file}"

if [ $? -ne 0 ]; then
    echo "错误：下载失败"
    exit 1
fi

echo ""
echo "下载完成: ${trunk_file}"

# 解压处理
if [[ "$trunk_file" == *.gz ]]; then
    echo "正在解压 .gz 文件..."
    gunzip -k "${trunk_file}" 2>/dev/null || gunzip "${trunk_file}"
    imgfile="${trunk_file%.gz}"
elif [[ "$trunk_file" == *.xz ]]; then
    echo "正在解压 .xz 文件..."
    xz -d "${trunk_file}"
    imgfile="${trunk_file%.xz}"
else
    imgfile="$trunk_file"
fi

# 如果解压后还是 .img.gz（双重压缩），继续处理
if [[ "$imgfile" == *.img.gz ]]; then
    echo "检测到双重压缩，继续解压..."
    gunzip "${imgfile}"
    imgfile="${imgfile%.gz}"
fi

# 重命名为 armbian.img
if [ -f "$imgfile" ] && [[ "$imgfile" == *.img ]]; then
    mv "$imgfile" armbian.img
    echo ""
    echo "✅ 已完成！保存为: armbian.img"
else
    echo ""
    echo "⚠️  解压后的文件: $imgfile"
    echo "请手动检查并重命名"
fi
